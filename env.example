# ============================================================
#  .env.example — Copy this to .env and fill in your values
#  .env is in .gitignore and will NEVER be committed to GitHub
# ============================================================

# ── Database (Supabase — free tier, 500MB Postgres) ──────────
# Sign up at: https://supabase.com → New project
# Get these from: Project Settings → API
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# ── Phase 2: AI Scoring (Groq — free tier) ──────────────────
# Sign up at: https://console.groq.com
# Free: 14,400 requests/day, no credit card needed
GROQ_API_KEY=your_groq_api_key_here

# ── Phase 2: AI Rewriting (Gemini — free tier) ───────────────
# Sign up at: https://aistudio.google.com/app/apikey
# Free: 1,500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# ── Reddit scraping ──────────────────────────────────────────
# No credentials needed! Reddit's .rss endpoint is public:
#   https://www.reddit.com/r/MachineLearning/hot.rss
# feedparser reads it directly. No API key, no OAuth, no account.

# ── Phase 4: Twitter / X posting ─────────────────────────────
# Get from: https://developer.twitter.com/en/portal/dashboard
# Free tier allows posting (write-only)
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# ── Phase 4: LinkedIn (official Posts API — no browser needed) ─
# Get these from: developer.linkedin.com → your app → Auth tab
# Requires: create an app, link a Company Page, request the
# "Sign In with LinkedIn using OpenID Connect" and "Share on
# LinkedIn" products (both self-serve, no approval needed).
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8765/callback

# ── Optional: Notification (free) ────────────────────────────
# Get from: https://ntfy.sh (free, no account needed for basic use)
# Sends you a phone notification when a post goes live
NTFY_TOPIC=your_unique_topic_name_here
