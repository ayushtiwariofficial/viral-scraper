# ============================================================
#  .env.example — Copy this to .env and fill in your values
#  .env is in .gitignore and will NEVER be committed to GitHub
# ============================================================

# ── Phase 2: AI Scoring (Groq — free tier) ──────────────────
# Sign up at: https://console.groq.com
# Free: 14,400 requests/day, no credit card needed
GROQ_API_KEY=your_groq_api_key_here

# ── Phase 2: AI Rewriting (Gemini — free tier) ───────────────
# Sign up at: https://aistudio.google.com/app/apikey
# Free: 1,500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# ── Reddit scraping (OAuth — required since May 2026) ────────
# Reddit deprecated unauthenticated .json access entirely.
# Register a free "script" app at: https://www.reddit.com/prefs/apps
# Free tier: 60-100 requests/min, no business justification needed
# at this volume. Use a dedicated Reddit account if possible (not
# your main personal account), and make sure 2FA is OFF for that
# account — script apps authenticate via username+password and
# can't complete a 2FA challenge.
REDDIT_CLIENT_ID=your_reddit_app_client_id
REDDIT_CLIENT_SECRET=your_reddit_app_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ── Phase 4: Twitter / X posting ─────────────────────────────
# Get from: https://developer.twitter.com/en/portal/dashboard
# Free tier allows posting (write-only)
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# ── Phase 4: LinkedIn (browser automation — no API key) ──────
# These are your actual LinkedIn login credentials
# Used by Playwright to log in once and save the session cookie
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password

# ── Optional: Notification (free) ────────────────────────────
# Get from: https://ntfy.sh (free, no account needed for basic use)
# Sends you a phone notification when a post goes live
NTFY_TOPIC=your_unique_topic_name_here
